# Third-party data is NOT redistributed here (licence unclear). Fetch it with
# `python scripts/build_realized.py` (pulls the Oxford-Man library from the
# Internet Archive). See data/README.md for provenance.
data/oxford_realized.csv
data/crypto_realized.csv
data/crypto_expanded_realized.csv
data/volare_*.parquet
data/volare_*_realized.csv
data/raw/

# LaTeX build artifacts
report/*.aux
report/*.log
report/*.out
report/*.toc
report/*.fdb_latexmk
report/*.fls
report/*.synctex.gz
report/*.pdf

# Internal planning / handoff / pre-registration docs — kept LOCAL only, never
# pushed (private repo). Purged from history via git-filter-repo. README.md,
# data/README.md and report/ stay tracked.
/HANDOFF.md
/ROADMAP.md
/docs/

# Local / internal-only (never committed, never on the remote)
/CLAUDE.md
/.claude/
# third-party tutorial notebooks (not ours to redistribute)
/extraipynb/

# Secrets / credentials — NEVER commit (e.g. VOLARE / vendor API tokens)
.env
*.env
.env.*
!.env.example          # but DO commit the template (no real secrets)
.netrc
secrets/
*.key
*.pem
credentials*.json
*token*.json
*_token
*.secret

# OS
.DS_Store

# Generated result artifacts (figures + JSON summaries) ARE committed as the
# deliverable; only transient/large intermediates are ignored.
